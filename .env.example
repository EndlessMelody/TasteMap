# =============================================================
# .env.example — Copy to .env and fill in real values
# Get free Groq key: console.groq.com
# Get Supabase keys: supabase.com/dashboard → Project Settings
# =============================================================

# --- Supabase PostgreSQL ---
# Transaction Pooler (port 6543) — for app runtime
DATABASE_URL=postgresql+asyncpg://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?prepared_statement_cache_size=0

# Direct Connection (port 5432) — for Alembic migrations only
DATABASE_URL_DIRECT=postgresql+asyncpg://postgres.[project-ref]:[password]@db.[project-ref].supabase.co:5432/postgres

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- Supabase Auth ---
# From: Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://[project-ref].supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
SUPABASE_JWT_SECRET=your-jwt-secret-here
SUPABASE_PROJECT_REF=your-project-ref-here

# --- AI / LLM (Groq) ---
# Free key at: console.groq.com
GROQ_API_KEY=gsk_your_key_here
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_VISION_MODEL=llama-3.2-11b-vision-preview
CULTURE_TEXT_MODEL=llama-3.3-70b-versatile

# --- Email / SMTP (optional) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password-here
